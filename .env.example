# Copy this file to ".env" for local testing, and fill in real values.
# On Render, set these same names in the dashboard under "Environment".

# A password you invent. Shortcuts must send this so only you can write rows.
API_TOKEN=make-up-a-long-random-string

# From the Dropbox App Console (https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=your-dropbox-app-key
DROPBOX_APP_SECRET=your-dropbox-app-secret

# Produced once by running:  python get_refresh_token.py
DROPBOX_REFRESH_TOKEN=your-dropbox-refresh-token

# Where the spreadsheet lives inside your app's Dropbox folder.
DROPBOX_FILE_PATH=/nfc_log.xlsx

# Local timezone for the human-readable time column (IANA name).
TIMEZONE=America/Chicago
